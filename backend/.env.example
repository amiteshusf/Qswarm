# Application
APP_NAME=qswarm-backend
APP_ENV=local
APP_DEBUG=true

# Database (PostgreSQL) — copy this file to `.env` and set your real URL.
# For hosted Postgres (e.g. Render), append: ?sslmode=require
DATABASE_URL=postgresql+psycopg://USER:PASSWORD@HOST:5432/DATABASE_NAME

# Jira (read-only). Leave JIRA_USE_STUB=true for local dev without Jira.
JIRA_BASE_URL=https://your-domain.atlassian.net
JIRA_EMAIL=you@example.com
JIRA_API_TOKEN=
# When true, or when token is empty, the Jira client returns stub data instead of calling Jira.
JIRA_USE_STUB=true
# Optional Atlassian accountId for assigning Sprint 1–generated draft Jira Tasks to a reviewer.
JIRA_DEFAULT_TEST_REVIEWER_ACCOUNT_ID=

# Optional internal placeholder (not full auth in Sprint 1)
INTERNAL_ACTOR_DEFAULT=system

# Coding intelligence for change planning (stub = deterministic heuristics, no external API)
CODING_PROVIDER=stub

# Playwright subprocess timeout for POST .../execute (seconds)
PLAYWRIGHT_EXECUTION_TIMEOUT_SECONDS=120

# GitHub PR creation (POST /automation/jobs/{id}/create-pr). Token required for real API calls.
GITHUB_TOKEN=
# Optional defaults when jobs are created without repo_owner / repo_name on the AutomationJob.
GITHUB_DEFAULT_REPO_OWNER=
GITHUB_DEFAULT_REPO_NAME=
GITHUB_API_BASE_URL=https://api.github.com
