# Application
APP_NAME=qswarm-backend
APP_ENV=local
APP_DEBUG=true

# Database (PostgreSQL) — copy this file to `.env` and set your real URL.
# For hosted Postgres (e.g. Render), append: ?sslmode=require
DATABASE_URL=postgresql+psycopg://USER:PASSWORD@HOST:5432/DATABASE_NAME

# Jira (read-only). Leave JIRA_USE_STUB=true for local dev without Jira.
JIRA_BASE_URL=https://your-domain.atlassian.net
JIRA_EMAIL=you@example.com
JIRA_API_TOKEN=
# When true, or when token is empty, the Jira client returns stub data instead of calling Jira.
JIRA_USE_STUB=true
# Optional Atlassian accountId for assigning Sprint 1–generated draft Jira Tasks to a reviewer.
JIRA_DEFAULT_TEST_REVIEWER_ACCOUNT_ID=

# Optional internal placeholder (not full auth in Sprint 1)
INTERNAL_ACTOR_DEFAULT=system

# Coding intelligence for change planning (stub = deterministic heuristics, no external API)
CODING_PROVIDER=stub

# Sprint 2 — automation_sessions.coding_engine: stub | claude_code | copilot_agent
#
# claude_code (Phase 2): real subprocess integration. When enabled, POST .../sessions/{id}/start
# runs plan via QSwarm, invokes this CLI in repo_path cwd, then reads plan files from disk for
# patch validation/apply. No shell — argv is built from COMMAND + shlex(EXTRA_ARGS) + "-p" + prompt.
# copilot_agent: local GitHub Copilot CLI (subprocess). Same workspace→patch flow as claude_code.
# Install the Copilot CLI and set COMMAND to the binary or an absolute path (PATH is not assumed).
# Typical argv: copilot + EXTRA_ARGS + -p + prompt (or gh copilot -- … — see GitHub docs).
QSWARM_CLAUDE_CODE_ENABLED=false
QSWARM_CLAUDE_CODE_COMMAND=claude
QSWARM_CLAUDE_CODE_EXTRA_ARGS=
QSWARM_CLAUDE_CODE_WORKING_MODE=one_shot
QSWARM_CLAUDE_CODE_ALLOW_REVISION=true
QSWARM_CLAUDE_CODE_TIMEOUT_SECONDS=600
QSWARM_COPILOT_AGENT_ENABLED=false
QSWARM_COPILOT_AGENT_COMMAND=copilot
QSWARM_COPILOT_AGENT_EXTRA_ARGS=
QSWARM_COPILOT_AGENT_ALLOW_REVISION=true
QSWARM_COPILOT_AGENT_TIMEOUT_SECONDS=600

# Playwright subprocess timeout for POST .../execute (seconds)
PLAYWRIGHT_EXECUTION_TIMEOUT_SECONDS=120

# GitHub: PAT for session workspace clone (HTTPS), job/session create-pr, and API calls.
# RepositoryConnection can set credential_reference to another env var name (auth_type=github_pat_env).
GITHUB_TOKEN=

# Managed workspace root for POST /automation/sessions/{id}/start when repo_path is missing (GitHub clone).
QSWARM_WORKSPACE_ROOT=/tmp/qswarm
QSWARM_GIT_CLONE_TIMEOUT_SECONDS=600
QSWARM_GIT_FETCH_TIMEOUT_SECONDS=120

# After clone (or missing node_modules on local path): npm ci if package-lock.json else npm install if package.json.
QSWARM_BOOTSTRAP_TIMEOUT_SECONDS=600
QSWARM_SKIP_BOOTSTRAP_IF_NODE_MODULES=true
# Hosted Playwright: `npx playwright install chromium` timeout after npm + package validation.
QSWARM_PLAYWRIGHT_BROWSER_INSTALL_TIMEOUT_SECONDS=900
# Optional defaults when jobs are created without repo_owner / repo_name on the AutomationJob.
GITHUB_DEFAULT_REPO_OWNER=
GITHUB_DEFAULT_REPO_NAME=
GITHUB_API_BASE_URL=https://api.github.com
